{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A lead record extracted from an Excel file",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" },
        "noteFields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        },
        "sector": { "type": "string" },
        "rating": { "type": "string" },
        "color": { "type": "string" },
        "completed": { "type": "boolean" },
        "updatedAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "companyName", "userId"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads scoped by userId"
    }
  }
}
